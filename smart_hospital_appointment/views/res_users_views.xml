<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_hospital_branch" model="ir.ui.view">
        <field name="name">res.users.form.hospital.branch</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']//group" position="inside">
                <group string="Hospital Branches" name="hospital_branches">
                    <field name="allowed_branch_ids" widget="many2many_tags"/>
                    <field name="branch_id" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_users_form_simple_modif_hospital_branch" model="ir.ui.view">
        <field name="name">res.users.preferences.form.hospital.branch</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='preferences']" position="inside">
                <group string="Hospital Branches">
                    <field name="allowed_branch_ids" widget="many2many_tags" readonly="1"/>
                    <field name="branch_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
