<odoo>
    <data>
        <record id="view_hospital_patient_tree" model="ir.ui.view">
            <field name="name">hospital.patient.tree</field>
            <field name="model">hospital.patient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="patient_code"/>
                    <field name="name"/>
                    <field name="age"/>
                    <field name="gender"/>
                    <field name="phone"/>
                    <field name="branch_id"/>
                </tree>
            </field>
        </record>

        <record id="view_hospital_patient_search" model="ir.ui.view">
            <field name="name">hospital.patient.search</field>
            <field name="model">hospital.patient</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="patient_code"/>
                    <field name="phone"/>
                    <field name="branch_id"/>
                    <filter name="group_branch" string="By Branch" context="{'group_by': 'branch_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_hospital_patient_form" model="ir.ui.view">
            <field name="name">hospital.patient.form</field>
            <field name="model">hospital.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                            <h2>
                                <field name="patient_code" readonly="1"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="age"/>
                                <field name="gender"/>
                                <field name="branch_id"/>
                                <field name="user_id"/>
                            </group>
                            <group>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="partner_id"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="address"/>
                            <field name="allergies"/>
                        </group>
                        <group>
                            <field name="medical_history"/>
                        </group>
                        <notebook>
                            <page string="Health Timeline">
                                <field name="appointment_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="appointment_datetime"/>
                                        <field name="doctor_id"/>
                                        <field name="state"/>
                                        <field name="notes"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hospital_patient" model="ir.actions.act_window">
            <field name="name">Patients</field>
            <field name="res_model">hospital.patient</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hospital_patient_search"/>
        </record>
    </data>
</odoo>
