<odoo>
    <data>
        <record id="view_hospital_doctor_tree" model="ir.ui.view">
            <field name="name">hospital.doctor.tree</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="experience_years"/>
                    <field name="consultation_fee"/>
                    <field name="rating"/>
                    <field name="is_unavailable"/>
                </tree>
            </field>
        </record>

        <record id="view_hospital_doctor_form" model="ir.ui.view">
            <field name="name">hospital.doctor.form</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="specialization"/>
                                <field name="experience_years"/>
                                <field name="consultation_fee"/>
                            </group>
                            <group>
                                <field name="rating" groups="smart_hospital_appointment.group_hospital_admin,smart_hospital_appointment.group_hospital_receptionist,base.group_system"/>
                                <field name="is_unavailable"/>
                                <field name="user_id" groups="smart_hospital_appointment.group_hospital_admin,base.group_system"/>
                                <field name="active" groups="smart_hospital_appointment.group_hospital_admin,base.group_system"/>
                            </group>
                        </group>
                        <group>
                            <field name="branch_ids" widget="many2many_tags" readonly="1" force_save="1"
                                   groups="smart_hospital_appointment.group_hospital_admin,smart_hospital_appointment.group_hospital_receptionist,base.group_system"/>
                            <field name="registered_by_id" readonly="1" force_save="1"
                                   groups="smart_hospital_appointment.group_hospital_admin,smart_hospital_appointment.group_hospital_receptionist,base.group_system"/>
                            <field name="branch_ids" widget="many2many_tags" readonly="1"
                                   groups="smart_hospital_appointment.group_hospital_doctor"/>
                        </group>
                        <group string="Performance">
                            <field name="total_patients" readonly="1"/>
                            <field name="completed_appointments" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Availability">
                                <field name="availability_ids" context="{'default_branch_id': context.get('hospital_branch_id')}">
                                    <tree editable="bottom">
                                        <field name="branch_id"/>
                                        <field name="day_of_week"/>
                                        <field name="start_time"/>
                                        <field name="end_time"/>
                                        <field name="slot_minutes"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Doctors</field>
            <field name="res_model">hospital.doctor</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'default_registered_by_id': uid}</field>
        </record>

        <record id="action_hospital_doctor_my_profile" model="ir.actions.act_window">
            <field name="name">My Profile</field>
            <field name="res_model">hospital.doctor</field>
            <field name="view_mode">form,tree</field>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="context">{'create': False, 'delete': False}</field>
        </record>
    </data>
</odoo>
