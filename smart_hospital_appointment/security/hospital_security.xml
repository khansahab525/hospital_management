<odoo>
    <data noupdate="0">
        <record id="module_category_hospital" model="ir.module.category">
            <field name="name">Hospital</field>
            <field name="description">Hospital Appointment Management</field>
            <field name="sequence">25</field>
        </record>

        <record id="group_hospital_admin" model="res.groups">
            <field name="name">Hospital Admin</field>
            <field name="category_id" ref="smart_hospital_appointment.module_category_hospital"/>
        </record>

        <record id="group_hospital_doctor" model="res.groups">
            <field name="name">Hospital Doctor</field>
            <field name="category_id" ref="smart_hospital_appointment.module_category_hospital"/>
        </record>

        <record id="group_hospital_receptionist" model="res.groups">
            <field name="name">Hospital Receptionist</field>
            <field name="category_id" ref="smart_hospital_appointment.module_category_hospital"/>
        </record>

        <record id="group_hospital_patient" model="res.groups">
            <field name="name">Hospital Patient</field>
            <field name="category_id" ref="smart_hospital_appointment.module_category_hospital"/>
        </record>

        <record id="hospital_appointment_doctor_rule" model="ir.rule">
            <field name="name">Doctor sees own appointments</field>
            <field name="model_id" ref="model_hospital_appointment"/>
            <field name="groups" eval="[(4, ref('smart_hospital_appointment.group_hospital_doctor'))]"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="hospital_appointment_patient_rule" model="ir.rule">
            <field name="name">Patient sees own appointments</field>
            <field name="model_id" ref="model_hospital_appointment"/>
            <field name="groups" eval="[(4, ref('smart_hospital_appointment.group_hospital_patient'))]"/>
            <field name="domain_force">[('patient_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
