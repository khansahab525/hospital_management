<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_patient_portal_rule" model="ir.rule">
        <field name="name">Hospital Patient: portal own record</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hospital_appointment_portal_rule" model="ir.rule">
        <field name="name">Hospital Appointment: portal own records</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="domain_force">[('patient_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hospital_branch_portal_rule" model="ir.rule">
        <field name="name">Hospital Branch: portal read active</field>
        <field name="model_id" ref="model_hospital_branch"/>
        <field name="domain_force">[('active', '=', True)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hospital_doctor_portal_rule" model="ir.rule">
        <field name="name">Hospital Doctor: portal read active</field>
        <field name="model_id" ref="model_hospital_doctor"/>
        <field name="domain_force">[('active', '=', True), ('is_unavailable', '=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hospital_doctor_availability_portal_rule" model="ir.rule">
        <field name="name">Hospital Doctor Availability: portal read</field>
        <field name="model_id" ref="model_hospital_doctor_availability"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
