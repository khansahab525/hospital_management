<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_hospital_branch_user" model="res.groups">
        <field name="name">Hospital Branch User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Filter hospital transactions by the user's current branch.</field>
    </record>

    <record id="group_hospital_branch_limited" model="res.groups">
        <field name="name">Hospital Branch Limited</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Limit branch master visibility for non-admin branch users.</field>
    </record>

    <record id="hospital_branch_user_rule" model="ir.rule">
        <field name="name">Hospital Branch: current branch only</field>
        <field name="model_id" ref="model_hospital_branch"/>
        <field name="domain_force">[('id', '=', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_limited'))]"/>
    </record>

    <record id="hospital_appointment_branch_rule" model="ir.rule">
        <field name="name">Hospital Appointment: current branch only</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="domain_force">[('branch_id', '=', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_user'))]"/>
    </record>

    <record id="hospital_patient_branch_rule" model="ir.rule">
        <field name="name">Hospital Patient: current branch only</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="domain_force">[('branch_id', '=', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_user'))]"/>
    </record>

    <record id="hospital_doctor_branch_rule" model="ir.rule">
        <field name="name">Hospital Doctor: current branch only</field>
        <field name="model_id" ref="model_hospital_doctor"/>
        <field name="domain_force">[('branch_ids', 'in', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_user'))]"/>
    </record>

    <record id="hospital_doctor_availability_branch_rule" model="ir.rule">
        <field name="name">Hospital Doctor Availability: current branch only</field>
        <field name="model_id" ref="model_hospital_doctor_availability"/>
        <field name="domain_force">[('branch_id', '=', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_user'))]"/>
    </record>

    <record id="hospital_appointment_medicine_line_branch_rule" model="ir.rule">
        <field name="name">Hospital Appointment Medicine Line: current branch only</field>
        <field name="model_id" ref="model_hospital_appointment_medicine_line"/>
        <field name="domain_force">[('appointment_id.branch_id', '=', hospital_branch_id)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_branch_user'))]"/>
    </record>
</odoo>
